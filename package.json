{
  "name": "slack-bot",
  "private": true,
  "packageManager": "pnpm@11.5.1",
  "type": "module",
  "scripts": {
    "start": "tsx src/main.ts",
    "start:prod": "node dist/main.js",
    "build": "tsup",
    "lint": "eslint .",
    "format:eslint": "eslint --fix .",
    "format:prettier": "prettier --write .",
    "format": "conc -m 1 pnpm:format:eslint pnpm:format:prettier",
    "test": "conc pnpm:test:type pnpm:test:unit",
    "test:type": "tsc --noEmit",
    "test:unit": "vitest run",
    "test:db": "RUN_DB_TESTS=1 vitest run tests/integration/migrations.test.ts",
    "migrate": "node-pg-migrate --migrations-dir migrations --tsconfig tsconfig.json --tsx",
    "migrate:up": "pnpm migrate up",
    "migrate:down": "pnpm migrate down",
    "migrate:redo": "pnpm migrate redo",
    "migrate:create": "pnpm migrate create"
  },
  "devDependencies": {
    "@commitlint/cli": "21.0.2",
    "@eslint/eslintrc": "3.3.5",
    "@fohte/eslint-config": "0.3.2",
    "@testcontainers/postgresql": "12.0.1",
    "@tsconfig/node-lts": "24.0.0",
    "@tsconfig/strictest": "2.0.8",
    "@types/node": "24.12.4",
    "@types/pg": "8.20.0",
    "concurrently": "10.0.0",
    "eslint": "10.4.1",
    "node-pg-migrate": "8.0.4",
    "pg": "8.21.0",
    "pino-pretty": "13.1.3",
    "prettier": "3.8.3",
    "tsup": "8.5.1",
    "tsx": "4.21.0",
    "typescript": "6.0.3",
    "vitest": "4.1.7"
  },
  "dependencies": {
    "@fohte/blog-publisher-contract": "0.1.0",
    "@hono/node-server": "2.0.4",
    "@slack/web-api": "7.15.1",
    "hono": "4.12.23",
    "pino": "10.3.1",
    "zod": "4.4.3"
  }
}
