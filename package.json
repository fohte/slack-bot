{
  "name": "slack-bot",
  "private": true,
  "packageManager": "pnpm@11.9.0",
  "type": "module",
  "scripts": {
    "start": "tsx src/main.ts",
    "start:prod": "node dist/main.js",
    "build": "tsup",
    "lint": "eslint .",
    "format:eslint": "eslint --fix .",
    "format:prettier": "prettier --write .",
    "format": "conc -m 1 pnpm:format:eslint pnpm:format:prettier",
    "test": "conc pnpm:test:type pnpm:test:unit",
    "test:type": "tsc --noEmit",
    "test:unit": "vitest run",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "tsx src/db/migrate.ts",
    "db:migrate:prod": "node dist/db/migrate.js"
  },
  "devDependencies": {
    "@commitlint/cli": "21.1.0",
    "@eslint/eslintrc": "3.3.5",
    "@fohte/eslint-config": "0.3.5",
    "@opentelemetry/context-async-hooks": "2.8.0",
    "@opentelemetry/core": "2.8.0",
    "@tsconfig/node-lts": "24.0.0",
    "@tsconfig/strictest": "2.0.8",
    "@types/node": "24.13.2",
    "concurrently": "10.0.3",
    "drizzle-kit": "0.31.10",
    "eslint": "10.6.0",
    "eslint-plugin-simple-import-sort": "13.0.0",
    "pino-pretty": "13.1.3",
    "prettier": "3.9.4",
    "tsup": "8.5.1",
    "tsx": "4.22.4",
    "typescript": "6.0.3",
    "vitest": "4.1.9"
  },
  "dependencies": {
    "@fohte/blog-publisher-contract": "0.1.0",
    "@fohte/service-kit": "0.1.4",
    "@hono/node-server": "2.0.4",
    "@kubernetes/client-node": "1.4.0",
    "@opentelemetry/api": "1.9.1",
    "@opentelemetry/auto-instrumentations-node": "0.77.0",
    "@opentelemetry/exporter-metrics-otlp-proto": "0.219.0",
    "@opentelemetry/exporter-trace-otlp-proto": "0.219.0",
    "@opentelemetry/resources": "2.8.0",
    "@opentelemetry/sdk-metrics": "2.8.0",
    "@opentelemetry/sdk-node": "0.219.0",
    "@opentelemetry/sdk-trace-base": "2.8.0",
    "@opentelemetry/semantic-conventions": "1.41.1",
    "@sentry/node": "10.58.0",
    "@sentry/opentelemetry": "10.58.0",
    "@slack/web-api": "7.16.0",
    "drizzle-orm": "0.45.2",
    "hono": "4.12.25",
    "pino": "10.3.1",
    "postgres": "3.4.9",
    "sharp": "0.35.3",
    "zod": "4.4.3"
  }
}
